PORT=4000

# PostgreSQL connection (required)
# Local example: postgresql://postgres:postgres@localhost:5432/heartbeat
# Railway usually provides this via service reference variable
DATABASE_URL=

# Set to true for managed Postgres requiring SSL (e.g. Railway/Supabase/Neon)
PGSSL=true

# JWT Authentication (required)
# Must be at least 32 characters long
JWT_SECRET=
JWT_ACCESS_EXPIRY=15m
JWT_REFRESH_EXPIRY=7d

# CORS allowed origins (comma-separated)
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:4000

# Email settings for password reset verification code.
# EMAIL_PROVIDER: auto | smtp | resend
# - auto: try SMTP first, fallback to Resend
# - smtp: only use SMTP
# - resend: only use Resend API
EMAIL_PROVIDER=auto

# Shared sender address
EMAIL_FROM=Heartbeat <noreply@yourdomain.com>

# SMTP settings (any SMTP service: Gmail SMTP / Mailgun SMTP / SendGrid SMTP / etc.)
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=

# Resend API settings (used when EMAIL_PROVIDER=resend, or auto fallback)
RESEND_API_KEY=
